{
  "name": "logging-secrets",
  "description": "Logging and secrets handling per pack.md Section 7.7 and registry.md Section 7.5",
  "tests": [
    {
      "name": "no_log_access_tokens",
      "secret_type": "access_token",
      "example": "Authorization: Bearer eyJhbGciOiJIUzI1NiIs...",
      "behavior": "must_not_log",
      "requirements": ["R-105", "R-283"],
      "description": "MUST NOT log access tokens"
    },
    {
      "name": "no_log_authorization_headers",
      "secret_type": "authorization_header",
      "example": "Authorization: Basic dXNlcjpwYXNz",
      "behavior": "must_not_log",
      "requirements": ["R-105", "R-283"],
      "description": "MUST NOT log Authorization headers"
    },
    {
      "name": "no_log_url_credentials",
      "secret_type": "url_credentials",
      "example": "https://user:password@registry.example.com/",
      "behavior": "must_not_log",
      "requirements": ["R-105", "R-283"],
      "description": "MUST NOT log credentials in URLs"
    },
    {
      "name": "redact_query_params",
      "url": "https://registry.example.com/pack.zip?token=secret123&sig=abc",
      "logged_url": "https://registry.example.com/pack.zip?token=REDACTED&sig=REDACTED",
      "requirements": ["R-106", "R-284"],
      "description": "MUST redact sensitive query parameters"
    },
    {
      "name": "redact_in_errors",
      "error_message": "Failed to fetch https://registry.example.com/pack.zip?token=REDACTED",
      "requirements": ["R-106", "R-284"],
      "description": "MUST redact in error messages"
    },
    {
      "name": "redact_in_diagnostics",
      "requirements": ["R-284"],
      "description": "MUST redact in diagnostic output"
    }
  ],
  "sensitive_parameters": [
    "token",
    "access_token",
    "api_key",
    "apikey",
    "secret",
    "password",
    "sig",
    "signature"
  ],
  "notes": "Per pack.md Section 7.7 and registry.md Section 7.5: Never log secrets, always redact sensitive data."
}
