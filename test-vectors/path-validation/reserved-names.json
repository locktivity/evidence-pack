{
  "name": "reserved-names",
  "description": "Windows reserved name validation per pack.md Section 2.3.4",
  "tests": [
    {
      "name": "con_rejected",
      "path": "artifacts/con",
      "valid": false,
      "expected_error": "reserved_name",
      "requirements": ["R-020", "R-021", "R-086"],
      "description": "Windows reserved name 'con' rejected"
    },
    {
      "name": "prn_rejected",
      "path": "artifacts/prn",
      "valid": false,
      "expected_error": "reserved_name",
      "requirements": ["R-020", "R-021", "R-086"],
      "description": "Windows reserved name 'prn' rejected"
    },
    {
      "name": "aux_rejected",
      "path": "artifacts/aux",
      "valid": false,
      "expected_error": "reserved_name",
      "requirements": ["R-020", "R-021", "R-086"],
      "description": "Windows reserved name 'aux' rejected"
    },
    {
      "name": "nul_rejected",
      "path": "artifacts/nul",
      "valid": false,
      "expected_error": "reserved_name",
      "requirements": ["R-020", "R-021", "R-086"],
      "description": "Windows reserved name 'nul' rejected"
    },
    {
      "name": "com1_rejected",
      "path": "artifacts/com1",
      "valid": false,
      "expected_error": "reserved_name",
      "requirements": ["R-020", "R-021", "R-086"],
      "description": "Windows reserved name 'com1' rejected"
    },
    {
      "name": "com9_rejected",
      "path": "artifacts/com9",
      "valid": false,
      "expected_error": "reserved_name",
      "requirements": ["R-020", "R-021", "R-086"],
      "description": "Windows reserved name 'com9' rejected"
    },
    {
      "name": "lpt1_rejected",
      "path": "artifacts/lpt1",
      "valid": false,
      "expected_error": "reserved_name",
      "requirements": ["R-020", "R-021", "R-086"],
      "description": "Windows reserved name 'lpt1' rejected"
    },
    {
      "name": "lpt9_rejected",
      "path": "artifacts/lpt9",
      "valid": false,
      "expected_error": "reserved_name",
      "requirements": ["R-020", "R-021", "R-086"],
      "description": "Windows reserved name 'lpt9' rejected"
    },
    {
      "name": "con_case_insensitive",
      "path": "artifacts/CON",
      "valid": false,
      "expected_error": "reserved_name",
      "requirements": ["R-020", "R-021", "R-086"],
      "description": "Reserved names are case-insensitive"
    },
    {
      "name": "con_mixed_case",
      "path": "artifacts/Con",
      "valid": false,
      "expected_error": "reserved_name",
      "requirements": ["R-020", "R-021", "R-086"],
      "description": "Reserved names are case-insensitive"
    },
    {
      "name": "con_in_subdirectory",
      "path": "artifacts/subdir/con",
      "valid": false,
      "expected_error": "reserved_name",
      "requirements": ["R-020", "R-021", "R-086"],
      "description": "Reserved names rejected anywhere in path"
    },
    {
      "name": "con_as_directory",
      "path": "artifacts/con/data.json",
      "valid": false,
      "expected_error": "reserved_name",
      "requirements": ["R-020", "R-021", "R-086"],
      "description": "Reserved names rejected as directory segments"
    },
    {
      "name": "con_with_extension_rejected",
      "path": "artifacts/con.txt",
      "valid": false,
      "expected_error": "reserved_name",
      "requirements": ["R-020", "R-021", "R-086"],
      "description": "Reserved names with extensions are rejected (Windows maps con.txt to CON device)"
    },
    {
      "name": "aux_with_extension_rejected",
      "path": "artifacts/aux.log",
      "valid": false,
      "expected_error": "reserved_name",
      "requirements": ["R-020", "R-021", "R-086"],
      "description": "Reserved names with extensions are rejected (Windows maps aux.log to AUX device)"
    },
    {
      "name": "prn_with_extension_rejected",
      "path": "artifacts/prn.doc",
      "valid": false,
      "expected_error": "reserved_name",
      "requirements": ["R-020", "R-021", "R-086"],
      "description": "Reserved names with extensions are rejected (Windows maps prn.doc to PRN device)"
    },
    {
      "name": "com1_with_extension_rejected",
      "path": "artifacts/com1.dat",
      "valid": false,
      "expected_error": "reserved_name",
      "requirements": ["R-020", "R-021", "R-086"],
      "description": "Reserved names with extensions are rejected (Windows maps com1.dat to COM1 device)"
    },
    {
      "name": "con_prefix_allowed",
      "path": "artifacts/config.json",
      "valid": true,
      "requirements": ["R-020"],
      "description": "Words starting with reserved names are allowed"
    },
    {
      "name": "con_suffix_allowed",
      "path": "artifacts/icon.png",
      "valid": true,
      "requirements": ["R-020"],
      "description": "Words ending with reserved names are allowed"
    }
  ],
  "all_reserved_names": ["con", "prn", "aux", "nul", "com1", "com2", "com3", "com4", "com5", "com6", "com7", "com8", "com9", "lpt1", "lpt2", "lpt3", "lpt4", "lpt5", "lpt6", "lpt7", "lpt8", "lpt9"],
  "notes": "Per pack.md Section 2.3.4: Reserved base names MUST NOT be used in path segments (case-insensitive), including with extensions. The base name is the portion before the first dot. MUST enforce on all platforms."
}
