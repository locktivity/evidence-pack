{
  "name": "excludes-references",
  "description": "Pack digest excludes referenced artifacts",
  "input": {
    "artifacts": [
      {
        "type": "embedded",
        "path": "artifacts/data.json",
        "digest": "sha256:1111111111111111111111111111111111111111111111111111111111111111",
        "size": 100
      },
      {
        "type": "reference",
        "name": "external-doc",
        "uri": "https://example.com/doc.pdf",
        "access": {"policy": "nda_required"},
        "digest": "sha256:9999999999999999999999999999999999999999999999999999999999999999"
      }
    ]
  },
  "expected": {
    "canonical_input": "artifacts/data.json\tsha256:1111111111111111111111111111111111111111111111111111111111111111\n"
  },
  "valid": true,
  "notes": "Only embedded artifacts are included in pack_digest computation"
}
